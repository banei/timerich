# TimeRich 环境变量配置
# cp .env.example .env 后修改必填项

MYSQL_ROOT_PASSWORD=ChangeMe_Root_20chars_min
MYSQL_APP_PASSWORD=ChangeMe_App_20chars_min
MYSQL_DATABASE=dca_dashboard
MYSQL_USER=dca_app

JWT_SECRET_KEY=please-change-this-jwt-secret-key-in-production
API_SECRET_KEY=please-change-this-api-key

DATABASE_URL=mysql+pymysql://dca_app:${MYSQL_APP_PASSWORD}@mysql:3306/dca_dashboard?charset=utf8mb4

FRONTEND_PORT=8050
BACKEND_PORT=8051
VITE_API_BASE_URL=http://localhost:8051
VITE_APP_TITLE=TimeRich

CORS_ORIGINS=http://localhost:8050,http://127.0.0.1:8050

LOG_LEVEL=INFO
SQL_ECHO=false
TZ=Asia/Shanghai

SCHEDULER_ENABLED=true
SCHEDULER_RUN_ON_START=false

DATA_FETCH_TIMEOUT=30
DATA_FETCH_RETRY=3
CACHE_TTL_REALTIME=15
CACHE_TTL_DAILY=240

BACKFILL_YEARS=10
DAILY_REFRESH_HOUR=22
DAILY_REFRESH_MINUTE=30

BACKUP_DIR=./backups
BACKUP_RETAIN_DAYS=30

NOTIFY_WEBHOOK_URL=
NOTIFY_WEBHOOK_FEISHU=

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
